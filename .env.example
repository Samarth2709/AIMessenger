# Copy to ~/Library/Application Support/AIMessenger/env and chmod 600.
TELEGRAM_BOT_TOKEN=123456789:replace-with-botfather-token
TELEGRAM_ALLOWED_USER_ID=123456789

# Optional overrides
# AIMESSENGER_DATA_DIR=/Users/you/Library/Application Support/AIMessenger
# AIMESSENGER_WORKING_DIR=/Users/you
# AIMESSENGER_PORT=8787
# DEFAULT_PROVIDER=codex
# JOB_TIMEOUT_MINUTES=360
# CODEX_COMMAND=codex
# CLAUDE_COMMAND=claude
