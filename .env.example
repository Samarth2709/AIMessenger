# Copy to the default AIMessenger env path for your OS and chmod 600.
# macOS: ~/Library/Application Support/AIMessenger/env
# Linux: ~/.local/state/AIMessenger/env
TELEGRAM_BOT_TOKEN=123456789:replace-with-botfather-token
TELEGRAM_ALLOWED_USER_ID=123456789

# Optional overrides
# AIMESSENGER_DATA_DIR=/absolute/path/to/AIMessenger-data
# AIMESSENGER_WORKING_DIR=/absolute/path/to/working-directory
# AIMESSENGER_PORT=8787
# DEFAULT_PROVIDER=codex
# JOB_TIMEOUT_MINUTES=360
# SELF_UPDATE_ENABLED=true
# SELF_UPDATE_DRAIN_SECONDS=45
# SELF_UPDATE_WATCHDOG_SECONDS=90
# CODEX_COMMAND=codex
# CODEX_LIVE_CONVERSATIONS=true
# CLAUDE_COMMAND=claude
# CODEX_MODEL=gpt-5.6-sol
# CLAUDE_MODEL=claude-sonnet-4-5
# GATEWAY_API_BASE=http://127.0.0.1:4000/v1
# GATEWAY_API_KEY=replace-with-a-local-LiteLLM-key
# GATEWAY_MODELS=glm-5.2,deepseek-v4-flash,deepseek-v4-pro
# Add kimi-k3 only after MOONSHOT_API_KEY is configured for the local gateway.
