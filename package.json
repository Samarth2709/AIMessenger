{
  "name": "aimessenger",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "start": "node dist/src/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "self-update": "tsx scripts/self-update-release.ts",
    "health": "bash scripts/health-check.sh",
    "telegram:whoami": "tsx scripts/telegram-whoami.ts",
    "memory": "tsx src/memory-cli.ts"
  },
  "dependencies": {
    "better-sqlite3": "12.11.1",
    "dotenv": "^17.2.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "4.1.10"
  }
}
